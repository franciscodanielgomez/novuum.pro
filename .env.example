# Supabase (cliente público — expuestos al browser)
PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
PUBLIC_SUPABASE_ANON_KEY=

# Supabase (server-side / admin — NO commitear nunca)
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_API_KEY_SECRET=

# Tauri (firma de actualizaciones del binario desktop)
TAURI_SIGNING_PRIVATE_KEY=
TAURI_SIGNING_PRIVATE_KEY_PATH=src-tauri/novum.key
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=

# Auto-update GitHub release (lo lee la UI de updater)
VITE_GITHUB_REPO=owner/repo
